# ==============================================================================
# CodeMentorHub Environment Variables Template (.env)
# Rename this file to '.env' and configure your values.
# IMPORTANT: Never commit '.env' files containing real secrets to version control!
# ==============================================================================

# ------------------------------------------------------------------------------
# Django Core Settings
# ------------------------------------------------------------------------------
# Security Warning: Keep the secret key used in production secret!
SECRET_KEY=DyP3nL4XDf3Jt40PSUCVcx5TJJ09USTQMvshcXnGyQg-tf_afPb7vGYw4tW8E01XNEE

# Set to True for development, False for production
DEBUG=True

# Comma-separated list of hosts/domain names that this Django site can serve
ALLOWED_HOSTS=localhost,127.0.0.1

# ------------------------------------------------------------------------------
# Database Settings (PostgreSQL)
# ------------------------------------------------------------------------------
# Standard database URL structure: postgres://USER:PASSWORD@HOST:PORT/DB_NAME
DATABASE_URL=postgres://postgres:@localhost:5432/codementorhub

# Alternative individual database credentials (in case you parse them individually)
DB_ENGINE=django.db.backends.postgresql
DB_NAME=codementorhub
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# ------------------------------------------------------------------------------
# Email Configuration (Gmail SMTP)
# ------------------------------------------------------------------------------
# Your Gmail address used to send emails (e.g., example@gmail.com)
EMAIL_HOST_USER=

# Your Gmail App Password (NOT your normal Gmail login password!)
# Learn how to create one: https://support.google.com/accounts/answer/185833
EMAIL_HOST_PASSWORD=

# The email address that emails appear to come from
DEFAULT_FROM_EMAIL=noreply@codementorhub.com

# ------------------------------------------------------------------------------
# Google Meet & Calendar API Integration
# ------------------------------------------------------------------------------
# Enable or disable Google Calendar API for generating actual Meet links
GOOGLE_CALENDAR_API_ENABLED=False

# The Google Calendar ID to insert events into (usually 'primary' or a specific calendar ID)
GOOGLE_CALENDAR_ID=primary

# Path to the Google Service Account JSON key file
GOOGLE_SERVICE_ACCOUNT_FILE=service-account.json
